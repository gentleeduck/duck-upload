root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}]
indent_style = tab
indent_size = 2

[*.{md,mdx,yaml,yml,toml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{css,scss}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
